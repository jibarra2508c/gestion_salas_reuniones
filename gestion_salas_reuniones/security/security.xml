<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <!-- Categoría para el módulo -->
        <record id="module_category_gestion_salas" model="ir.module.category">
            <field name="name">Gestión de Salas de Reuniones</field>
            <field name="description">Categoría para los permisos del módulo de salas de reuniones</field>
            <field name="sequence">20</field>
        </record>

        <!-- Grupo Reuniones: los usuarios pertenecientes a este grupo
             podrán ver el menú y gestionar salas y reuniones sin ser superusuario -->
        <record id="group_reuniones" model="res.groups">
            <field name="name">Reuniones</field>
            <field name="category_id" ref="module_category_gestion_salas"/>
            <field name="comment">Grupo de usuarios que pueden gestionar salas y reuniones.</field>
        </record>

    </data>
</odoo>
