<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista lista de reuniones (con barra de progreso en asientos ocupados) -->
    <record id="view_reunion_tree" model="ir.ui.view">
        <field name="name">gestion.salas.reunion.tree</field>
        <field name="model">gestion.salas.reunion</field>
        <field name="arch" type="xml">
            <tree string="Reuniones">
                <field name="nombre"/>
                <field name="sala_id"/>
                <field name="fecha_inicio"/>
                <field name="duracion"/>
                <field name="asientos"/>
                <field name="asientos_ocupados" widget="progressbar" string="Asientos ocupados"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario de reuniones -->
    <record id="view_reunion_form" model="ir.ui.view">
        <field name="name">gestion.salas.reunion.form</field>
        <field name="model">gestion.salas.reunion</field>
        <field name="arch" type="xml">
            <form string="Reunión">
                <sheet>
                    <div class="oe_title">
                        <label for="nombre"/>
                        <h1>
                            <field name="nombre" placeholder="Nombre de la reunión..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sala_id"/>
                            <field name="fecha_inicio"/>
                            <field name="duracion"/>
                        </group>
                        <group>
                            <field name="responsable_id"/>
                            <field name="asientos"/>
                            <field name="asientos_ocupados" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Asistentes">
                            <field name="asistente_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de ventana para Reuniones -->
    <record id="action_reunion" model="ir.actions.act_window">
        <field name="name">Reuniones</field>
        <field name="res_model">gestion.salas.reunion</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea una nueva reunión
            </p>
            <p>
                Aquí podrás gestionar las reuniones de la empresa.
            </p>
        </field>
    </record>

</odoo>
